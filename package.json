{
  "name": "geospatialanalyzer",
  "version": "2.0.0",
  "description": "GeospatialAnalyzer HTTP-API",
  "author": "Landesamt für Geobasisinformation Sachsen (GeoSN) and con terra GmbH",
  "private": true,
  "license": "GPL-3.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:watch": "jest --watch --silent=false",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:e2e:watch": "jest --watch --config ./test/jest-e2e.json"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.40",
    "@terraformer/arcgis": "^2.1.2",
    "@terraformer/wkt": "^2.2.1",
    "@types/node": "^25.9.1",
    "class-transformer": "^0.5.1",
    "js-yaml": "^4.1.1",
    "openapi-validator-middleware": "^3.2.6",
    "pg": "^8.21.0",
    "proj4": "^2.20.8",
    "proj4-list": "^1.0.4",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "../test/dotenv-config.ts"
    ]
  }
}
